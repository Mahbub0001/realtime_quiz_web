# ─── Core Security ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_long_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL=sqlite:///./quiz_platform.db

# Production (Supabase PostgreSQL) — get from Supabase → Project Settings → Database → URI:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Local development:
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000

# Production:
# FRONTEND_URL=https://your-app.vercel.app
# BACKEND_PUBLIC_URL=https://your-backend.onrender.com

# ─── Supabase Storage (for question image uploads) ────────────────────────────
# Get from Supabase → Project Settings → API
# Leave blank in local dev to disable image uploads (or set up a local Supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-from-supabase-api-settings
